# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:password@localhost:5432/hotspots_campaign?schema=public"

# Session encryption key — must be at least 32 characters, keep secret
IRON_SESSION_SECRET="change-me-to-a-random-32-char-secret-string"

# Admin page password — passed as ?secret= query param in the URL
ADMIN_SECRET="change-me-to-a-secret-admin-key"
