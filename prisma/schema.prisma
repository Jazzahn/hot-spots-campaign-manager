generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  CAMPAIGN_MANAGER
  PLAYER
}

enum GameRules {
  BATTLETECH
  ALPHA_STRIKE
}

enum CommandType {
  MERCENARY
  REGULAR_MILITARY
}

enum UnitType {
  BATTLEMECH
  COMBAT_VEHICLE
  BATTLE_ARMOR
  INFANTRY
}

enum TechBase {
  IS
  CLAN
  MIXED
}

enum UnitStatus {
  OPERATIONAL
  ARMOR_DAMAGE
  STRUCTURE_CRIT
  CRIPPLED
  DESTROYED
  TRULY_DESTROYED
}

enum ContractType {
  RAID
  EXPEDITION
  PIRATE_HUNT
  GARRISON
  INVASION
  RETAINER
  ACTS_OF_PIRACY
}

enum ContractStatus {
  PENDING
  ACTIVE
  COMPLETED
  BROKEN
}

enum SupportType {
  NONE
  STRAIGHT
  BATTLE
}

enum CommandRights {
  INTEGRATED
  HOUSE
  LIAISON
  INDEPENDENT
}

enum TrackResult {
  ALL_OBJECTIVES
  SUCCESS
  UNSUCCESSFUL
  INCOMPLETE
}

enum TransactionCategory {
  MAINTENANCE
  COMBAT_PAY
  TRANSPORT
  REPAIR
  REARM
  PURCHASE
  SELL
  SALVAGE
  UNIT_TRAINING
  PILOT_HIRE
  UNIT_PURCHASE
  COMMAND_TRAINING
  BATTLEFIELD_LOSS_COMPENSATION
  DEBT_INTEREST
  OTHER
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  callsign  String   @unique
  passHash  String
  role      UserRole @default(PLAYER)
  companies Company[]
  campaigns Campaign[]
  createdAt DateTime @default(now())
}

model Campaign {
  id                String    @id @default(cuid())
  name              String
  gameRules         GameRules @default(BATTLETECH)
  currentMonth      Int       @default(1)
  inGameStartYear   Int       @default(3151)
  inGameStartMonth  Int       @default(1)
  background        String?
  managedById  String?
  managedBy    User?     @relation(fields: [managedById], references: [id])
  inviteKey    String?   @unique

  companies Company[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Company {
  id              String      @id @default(cuid())
  campaignId      String
  campaign        Campaign    @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  userId          String?
  user            User?       @relation(fields: [userId], references: [id])
  name            String
  commandType     CommandType @default(MERCENARY)
  background      String?
  parentCommand   String?
  rankLevel       Int?
  warchest        Int         @default(3000)
  reputation      Int         @default(1)
  scale           Int         @default(1)
  trackingJumps   Boolean     @default(false)
  currentLocation String?
  companyOptions  Json?
  // Dummy per-campaign company that owns unassigned/OPFOR contracts; hidden from player listings
  isHolding       Boolean     @default(false)

  units        Unit[]
  pilots       Pilot[]
  contracts    Contract[]
  transactions Transaction[]
  randomContractOffers RandomContractOffer[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Unit {
  id                 String     @id @default(cuid())
  companyId          String
  company            Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name               String
  chassis            String
  model              String
  unitType           UnitType   @default(BATTLEMECH)
  tonnage            Int
  battleValue        Int
  pointValue         Int?
  techBase           TechBase   @default(IS)
  status             UnitStatus @default(OPERATIONAL)
  isOmni             Boolean    @default(false)
  currentConfig      String?
  availableNextTrack Boolean    @default(true)
  isTemporaryHire    Boolean    @default(false)
  isSalvaged         Boolean    @default(false)
  originalOwner      String?
  notes              String?

  pilots     Pilot[]
  trackUnits TrackUnit[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Pilot {
  id              String   @id @default(cuid())
  companyId       String
  company         Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  unitId          String?
  unit            Unit?    @relation(fields: [unitId], references: [id], onDelete: SetNull)
  name            String
  callsign        String?
  isNamed         Boolean  @default(true)
  // Skill levels (the actual game stats)
  gunnery         Int      @default(4)
  piloting        Int      @default(5)
  edgeTokens      Int      @default(1)
  edgeAbilities   String[] @default([])
  // SP invested in each category (cumulative)
  spGunnery       Int      @default(0)
  spPiloting      Int      @default(0)
  spEdgeTokens    Int      @default(0)
  spEdgeAbilities Int      @default(0)
  totalSPEarned   Int      @default(0)
  // Derived
  handicap        Int      @default(0)
  // Status
  wounds          Int      @default(0)
  isKilled        Boolean  @default(false)
  mvpCount        Int      @default(0)
  isTemporaryHire Boolean  @default(false)

  trackPilots TrackPilot[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Contract {
  id           String         @id @default(cuid())
  companyId    String
  company      Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  hotSpot      String
  contractName String
  contractType ContractType   @default(GARRISON)
  scale        Int            @default(1)
  durationMonths Int          @default(3)
  status       ContractStatus @default(PENDING)
  // Terms
  basePayPct      Int          @default(100)
  supportType     SupportType  @default(STRAIGHT)
  supportPct      Int          @default(100)
  salvageRightsPct Int         @default(0)
  commandRights   CommandRights @default(INDEPENDENT)
  transportPct    Int          @default(100)
  // Presented (default) terms as offered by the employer, recorded for the negotiation audit trail
  defaultBasePayPct      Int?
  defaultSupportType     SupportType?
  defaultSupportPct      Int?
  defaultSalvageRightsPct Int?
  defaultCommandRights   CommandRights?
  defaultTransportPct    Int?
  // Timeline
  startMonth   Int?
  endMonth     Int?
  notes        String?
  isReady      Boolean @default(false)
  conflictMonth Int    @default(1)
  companyMonthReady         Boolean @default(false)
  conflictAdvancedThisMonth Boolean @default(false)
  // OPFOR placeholder contract (owned by a holding company); excluded from finances/advancement
  isOpposingForce Boolean @default(false)

  tracks Track[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Track {
  id          String      @id @default(cuid())
  contractId  String
  contract    Contract    @relation(fields: [contractId], references: [id], onDelete: Cascade)
  trackNumber Int
  month       Int
  trackType   String
  scale       Int         @default(1)
  result      TrackResult @default(INCOMPLETE)
  playerVP    Int         @default(0)
  opponentVP  Int         @default(0)
  combatPay   Int         @default(0)
  spToNamedPilots Int     @default(0)
  notes       String?

  trackUnits   TrackUnit[]
  trackPilots  TrackPilot[]
  salvageItems SalvageItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TrackUnit {
  id           String     @id @default(cuid())
  trackId      String
  track        Track      @relation(fields: [trackId], references: [id], onDelete: Cascade)
  unitId       String
  unit         Unit       @relation(fields: [unitId], references: [id], onDelete: Cascade)
  damageResult UnitStatus @default(OPERATIONAL)
  retreated    Boolean    @default(false)

  @@unique([trackId, unitId])
}

model TrackPilot {
  id              String @id @default(cuid())
  trackId         String
  track           Track  @relation(fields: [trackId], references: [id], onDelete: Cascade)
  pilotId         String
  pilot           Pilot  @relation(fields: [pilotId], references: [id], onDelete: Cascade)
  wasMVP          Boolean @default(false)
  spEarned        Int    @default(0)
  spToGunnery     Int    @default(0)
  spToPiloting    Int    @default(0)
  spToEdgeTokens  Int    @default(0)
  spToEdgeAbilities Int  @default(0)

  @@unique([trackId, pilotId])
}

model SalvageItem {
  id               String  @id @default(cuid())
  trackId          String
  track            Track   @relation(fields: [trackId], references: [id], onDelete: Cascade)
  unitName         String
  chassis          String?
  battleValue      Int
  salvageValue     Int
  playerShare      Int
  wasClaimed       Boolean @default(false)
  wasRejected      Boolean @default(false)
  claimedByPlayer  String?

  createdAt DateTime @default(now())
}

model Transaction {
  id             String              @id @default(cuid())
  companyId      String
  company        Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  month          Int
  category       TransactionCategory
  amount         Int
  description    String
  runningBalance Int
  isPending      Boolean @default(false)
  contractId     String?
  trackId        String?

  createdAt DateTime @default(now())
}

// A rolled-but-not-yet-accepted Dobless random contract offer. One per company per
// campaign month (enforced by the unique index) so a roll cannot be re-generated by
// closing/reopening the dialog.
model RandomContractOffer {
  id            String   @id @default(cuid())
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  campaignMonth Int
  hiringHall    String
  payload       Json
  status        String   @default("OPEN") // OPEN | CONSUMED
  createdAt     DateTime @default(now())

  @@unique([companyId, campaignMonth])
}
